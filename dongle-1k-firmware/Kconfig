config DONGLE_SHELL_RELAY
    bool "ESB shell relay on dongle"
    default y
    help
      Single button press when paired requests a shell session from the
      keyboard over ESB. I/O is forwarded via USB CDC UART.

config DONGLE_SHELL_RELAY_INACTIVITY_S
    int "Dongle shell relay inactivity timeout (seconds, 0 = disabled)"
    default 60
    range 0 3600
    depends on DONGLE_SHELL_RELAY
    help
      Stop the shell relay session if no SHELL_POLL or SHELL_DATA is received
      from the keyboard for this many seconds. 0 disables the timeout.

config DONGLE_SHELL_RELAY_INPUT_BUF_SIZE
    int "Shell relay CDC input ring buffer size (bytes)"
    default 256
    range 64 4096
    depends on DONGLE_SHELL_RELAY

config DONGLE_SHELL_RELAY_FIFO_FULL_RETRY_MS
    int "Shell relay retry delay when ESB ACK FIFO is full (ms)"
    default 2000
    range 100 10000
    depends on DONGLE_SHELL_RELAY

config DONGLE_SHELL_RELAY_RETRY_MS
    int "Shell relay SHELL_REQ retry interval (ms)"
    default 200
    range 50 5000
    depends on DONGLE_SHELL_RELAY

config DONGLE_SHELL_RELAY_POLL_WATCHDOG_MS
    int "Shell relay poll watchdog timeout (ms, 0 = disabled)"
    default 1000
    range 0 30000
    depends on DONGLE_SHELL_RELAY
    help
      If no SHELL_POLL is received from the keyboard for this many ms while
      a shell session is active and confirmed, the dongle assumes the
      keyboard has gone away (e.g. endpoint switched to BLE), flushes the
      stale ACK FIFO, and re-issues SHELL_REQ so the session recovers when
      the keyboard comes back. 0 disables the watchdog.


config DONGLE_SHELL_RELAY_OUTPUT_BUF_SIZE
    int "Shell relay CDC output ring buffer size (bytes)"
    default 2048
    range 256 8192
    depends on DONGLE_SHELL_RELAY
    help
      Buffers keyboard shell output before writing to the CDC UART TX FIFO.
      Prevents bytes from being dropped when a USB bulk-IN transfer is already
      in flight. Must be larger than CONFIG_USB_CDC_ACM_RINGBUF_SIZE.

config DONGLE_SHELL_RELAY_TX_CHUNK_MAX
    int "Max bytes per uart_fifo_fill call when draining output ring"
    default 64
    range 16 256
    depends on DONGLE_SHELL_RELAY

config DONGLE_SHELL_RELAY_ALWAYS_ON
    bool "Always-on shell relay"
    default n
    depends on DONGLE_SHELL_RELAY
    help
      When enabled: the relay is not disconnected on inactivity, the
      dongle re-initiates the relay automatically if the keyboard drops
      it (ESB_PKT_SHELL_STOP), and the relay is requested immediately
      on connection (pairing complete or known peer at boot).

